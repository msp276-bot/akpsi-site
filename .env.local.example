# --- Supabase (shared portal backend) -------------------------------------
# Copy this file to `.env.local` and fill in the two values from your Supabase
# project: Dashboard → Project Settings → API.
#
# When these are BLANK, the portal runs in mock mode (in-browser demo accounts,
# nothing shared). When they're set, the portal uses the real shared backend and
# only emails added to the `members` roster can sign in.
#
# Both values are public/browser-safe — the anon key is limited by Row-Level
# Security. Never put the Supabase *service_role* key here or anywhere in the app.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
